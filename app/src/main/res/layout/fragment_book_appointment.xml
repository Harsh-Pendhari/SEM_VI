<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:background="@drawable/primary_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_calender"/>

                <ImageView
                    android:layout_width="230dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/appointments_txt"/>
            </LinearLayout>

            <!-- Profile -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_male"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Hello, Shrutika!"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#111111"/>

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="32 yrs"
                        android:textSize="13sp"
                        android:textColor="#666666"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- FORM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Doctor Dropdown -->
            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Select Doctor"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#111111"/>

            <Spinner
                android:id="@+id/spinnerDoctors"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="6dp"/>

            <!-- Date -->
            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Appointment Date"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#111111"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/etAppointmentDate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Select Date"
                android:focusable="false"
                android:clickable="true"
                android:padding="12dp"
                android:layout_marginTop="6dp"/>

            <!-- Time -->
            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Appointment Time"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#111111"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/etAppointmentTime"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Select Time"
                android:focusable="false"
                android:clickable="true"
                android:padding="12dp"
                android:layout_marginTop="6dp"/>

            <!-- Book Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBookAppointment"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="Book Appointment"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_add_medicine_gradient"
                app:backgroundTint="@null"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>