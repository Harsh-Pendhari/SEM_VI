<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/primary_bg"
            android:padding="16dp">

            <!-- Back Button -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_arrow_left"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"/>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blood Pressure"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:layout_centerInParent="true"/>

        </RelativeLayout>


        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/transparentBg"
            android:padding="20dp">

            <!-- Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/transparentBg"
                android:padding="20dp">

                <!-- Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blood Pressure (mmHg)"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111111"/>

                <!-- Input -->
                <EditText
                    android:id="@+id/etBloodPressure"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:hint="Enter value (e.g. 120/80)"
                    android:textColorHint="@color/grey"
                    android:textColor="@color/black"
                    android:padding="12dp"
                    android:textSize="16sp"
                    android:inputType="text"/>

                <!-- Last Value -->
                <TextView
                    android:id="@+id/tvLastValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Last recorded: --"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

            </LinearLayout>


            <!-- Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveBP"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:text="Enter New Data"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_add_medicine_gradient"
                app:backgroundTint="@null"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>